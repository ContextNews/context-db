# Local / AWS RDS connection string
AWS_DB_URL=postgresql://user:pass@localhost:5432/app

# Neon — pooled (use for application connections)
NEON_DB_URL_POOLED=postgresql://user:pass@ep-xxx-pooler.eu-west-2.aws.neon.tech/dbname?sslmode=require&channel_binding=require

# Neon — direct (use for migrations)
NEON_DB_URL_DIRECT=postgresql://user:pass@ep-xxx.eu-west-2.aws.neon.tech/dbname?sslmode=require&channel_binding=require
